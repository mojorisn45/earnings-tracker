# Copy this to secrets.toml (for local dev) or paste into Streamlit Cloud's
# Secrets UI (Settings → Secrets).
#
# Generate a GitHub PAT at: https://github.com/settings/tokens
#   → Fine-grained token → select the earnings-tracker repo
#   → Permissions: Contents = Read and write
#
# DO NOT commit secrets.toml to git — it's in .gitignore.

[github]
token = "github_pat_xxxxxxxxxxxx"
repo  = "mojorisn45/earnings-tracker"
